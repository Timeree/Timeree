{
  "name": "Minimal-Apt-Pip",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "installPip": true,
      "installConda": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "installYarn": true,
      "installPnpm": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": []
    }
  },
  "forwardPorts": [],
  "remoteUser": "vscode",
  "postCreateCommand": "apt update && apt install -y curl wget zip unzip microsocks build-essential; pip install pyftpdlib;"
}
